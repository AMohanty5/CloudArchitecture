        ]
      }
    },
    "/ai/jobs/{id}/proposal": {
      "get": {
        "operationId": "AiController_proposal",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The generated model held for review (the proposal), for the accept/reject diff UI."
          }
        },
        "tags": [
