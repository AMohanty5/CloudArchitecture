    }
  },
  "info": {
    "title": "CloudArchitect Core API",
    "description": "System of record for CAML architectures (blueprint doc 03).",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "components": {
    "schemas": {
      "CreateArchitectureDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable architecture name."
          },
          "description": {
            "type": "string"
          },
          "workspaceId": {
            "type": "string",
            "description": "Workspace id (defaults to the single-tenant workspace)."
          },
          "catalogVersion": {
            "type": "string",
            "description": "Catalog version to pin (defaults to \"dev\")."
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateArchitectureDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Rename the architecture."
          },
          "description": {
            "type": "string",
            "description": "Update the description."
          },
          "lifecycle": {
            "type": "string",
            "description": "Lifecycle status: draft | in_review | approved | published | archived | template."
          },
          "tags": {
            "description": "Free-form tags (normalized: trimmed, lowercased, deduped, max 12).",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "folderId": {
            "type": "string",
            "nullable": true,
            "description": "Move into a folder by id, or null to unfile. 404 if the folder is unknown."
          }
        }
      },
      "DuplicateArchitectureDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the duplicated architecture."
          }
        },
        "required": [
          "name"
        ]
      },
      "CommitDto": {
        "type": "object",
        "properties": {
          "expectedParent": {
            "type": "string",
            "description": "Optimistic lock — the commit hash this change is based on. 409 if the head moved."
          },
          "message": {
            "type": "string",
            "description": "Commit message."
          },
          "model": {
            "type": "object",
            "description": "Full CAML model (mutually exclusive with patch)."
          },
          "patch": {
            "description": "RFC-6902 patch applied to the parent commit (mutually exclusive with model).",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "layout": {
            "type": "object",
            "description": "Layout sidecar — positions/sizes, excluded from the content hash."
          }
        },
        "required": [
          "expectedParent",
          "message"
        ]
      },
      "CreateFolderDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Folder name (unique per workspace)."
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateFolderDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "New folder name."
          }
        },
        "required": [
          "name"
        ]
      },
      "GenerateDto": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Natural-language description of the architecture to generate."
          },
          "provider": {
            "type": "string",
            "description": "Target cloud provider (defaults to aws).",
            "enum": [
              "aws",
              "azure",
              "gcp"
            ]
          }
        },
        "required": [
          "prompt"
        ]
      }
    }
  }
}
