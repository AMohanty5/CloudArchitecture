{
  "name": "@cac/core",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "migrate": "tsx src/database/migrate.cli.ts",
    "seed": "tsx src/database/seed.cli.ts",
    "openapi": "node dist/openapi.cli.js",
    "test": "vitest run",
    "test:int": "vitest run -c vitest.integration.config.mts"
  },
  "dependencies": {
    "@cac/caml": "workspace:*",
    "@cac/catalog": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@cac/api-client": "workspace:*",
    "@cac/config": "workspace:*",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
